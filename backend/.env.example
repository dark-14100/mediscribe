# --- Runtime ---
# development | test | production. In production, API docs are disabled,
# a weak/placeholder JWT secret aborts startup, and misconfigured B2 storage
# fails closed instead of silently using non-persistent in-memory storage.
ENVIRONMENT=development

# --- Database ---
# Local (docker-compose):   postgresql+asyncpg://medscribe:medscribe@postgres:5432/medscribe
# Supabase (production):    postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=postgresql+asyncpg://medscribe:medscribe@postgres:5432/medscribe

# --- Redis ---
# Local (docker-compose):   redis://redis:6379/0
# Upstash (production):     rediss://default:PASSWORD@HOST:6379/0?ssl_cert_reqs=none
# NOTE: in production a plaintext redis:// URL to a non-local host aborts startup —
# the broker/cache carries PHI-derived data and must use TLS (rediss://).
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET_KEY=change_me_to_a_long_random_string_at_least_32_chars
SECRET_KEY=change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
# One clinical shift (8h). Kept short to limit the blast radius of a stolen token.
JWT_EXPIRE_MINUTES=480

# --- Groq (LLM + Whisper) ---
GROQ_API_KEY=

# --- Backblaze B2 (audio storage) ---
# Use a PRIVATE bucket. Audio is fetched via short-lived signed URLs minted by
# GET /pipeline/audio/{visit_id}; only the object key is persisted on the visit.
BACKBLAZE_KEY_ID=
BACKBLAZE_APP_KEY=
BACKBLAZE_BUCKET=
AUDIO_URL_TTL_SECONDS=300

# --- ML / pipeline tunables ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
DRIFT_THRESHOLD=0.25
COGNITIVE_LOAD_THRESHOLD=6

# --- De-identification (strip PHI from text before the LLM) ---
# off | on (fail-open) | enforce (fail-closed)
DEID_MODE=on
# Opt-in Layer-2 NER (default off = rules-only, no extra deps)
DEID_USE_NER=false
DEID_NER_MODEL=en_core_web_lg
DEID_REDACT_DATES=true
DEID_FLAG_RESIDUAL=true

# --- Grounding gate (faithfulness of SOAP claims vs transcript) ---
# off | warn (compute + surface, never block) | enforce
GROUNDING_MODE=warn
# Opt-in LLM second pass (default off = rules-only, no Groq cost)
GROUNDING_USE_LLM=false
GROUNDING_LLM_FIELDS=assessment,plan
GROUNDING_MODEL=llama-3.3-70b-versatile
GROUNDING_GROUNDED_THRESHOLD=0.6
GROUNDING_PARTIAL_THRESHOLD=0.3

# --- Upload / payload limits ---
MAX_AUDIO_UPLOAD_BYTES=26214400
MAX_TRANSCRIPT_LINES=5000
MAX_TRANSCRIPT_LINE_CHARS=10000

# --- Rate limiting (slowapi "<count>/<period>") ---
# Backed by REDIS_URL so limits hold across workers. Disabled automatically
# when ENVIRONMENT=test.
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_PIPELINE=10/minute

# --- HTTP / CORS ---
# Auth uses HttpOnly cookies with credentials, so this MUST list the exact
# frontend origin(s) — no "*". In production the frontend must be served over
# HTTPS (Secure; SameSite=None cookies require it).
CORS_ORIGINS=http://localhost:3000
