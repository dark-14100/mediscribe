# --- Runtime ---
# development | test | production. In production, API docs are disabled,
# a weak/placeholder JWT secret aborts startup, and misconfigured B2 storage
# fails closed instead of silently using non-persistent in-memory storage.
ENVIRONMENT=development

# --- Database ---
# Local (docker-compose):   postgresql+asyncpg://medscribe:medscribe@postgres:5432/medscribe
# Supabase (production):    postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=postgresql+asyncpg://medscribe:medscribe@postgres:5432/medscribe

# --- Redis ---
# Local (docker-compose):   redis://redis:6379/0
# Upstash (production):     rediss://default:PASSWORD@HOST:6379/0?ssl_cert_reqs=none
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET_KEY=change_me_to_a_long_random_string_at_least_32_chars
SECRET_KEY=change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Groq (LLM + Whisper) ---
GROQ_API_KEY=

# --- Backblaze B2 (audio storage) ---
BACKBLAZE_KEY_ID=
BACKBLAZE_APP_KEY=
BACKBLAZE_BUCKET=

# --- ML / pipeline tunables ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
DRIFT_THRESHOLD=0.25
COGNITIVE_LOAD_THRESHOLD=6

# --- Upload / payload limits ---
MAX_AUDIO_UPLOAD_BYTES=26214400
MAX_TRANSCRIPT_LINES=5000
MAX_TRANSCRIPT_LINE_CHARS=10000

# --- Rate limiting (slowapi "<count>/<period>") ---
# Backed by REDIS_URL so limits hold across workers. Disabled automatically
# when ENVIRONMENT=test.
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_PIPELINE=10/minute

# --- HTTP / CORS ---
CORS_ORIGINS=http://localhost:3000
